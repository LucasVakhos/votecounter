{
  "name": "rhymers-ts",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @rhymers/api",
    "dev:api": "npm run dev --workspace @rhymers/api",
    "dev:web": "npm run dev --workspace @rhymers/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
