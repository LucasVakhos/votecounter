{
  "name": "rhymers-ts",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @rhymers/api",
    "dev:api": "npm run dev --workspace @rhymers/api",
    "dev:web": "npm run dev --workspace @rhymers/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace @rhymers/api",
    "migrate:verify": "npm run migrate:verify --workspace @rhymers/api",
    "ci": "npm run build && npm run test && npm run migrate:verify"
  }
}
