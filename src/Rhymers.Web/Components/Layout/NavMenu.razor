@using Rhymers.Web.Services
@using Rhymers.Core.Models
@inject AuthorizationWebService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Rhymers</a>
        <div class="ms-auto">
            @if (currentUser != null)
            {
                <span class="text-light me-3">
                    <strong>@currentUser.DisplayName</strong> 
                    <small class="badge @GetRoleBadgeClass(currentUser.Role)">@GetRoleDisplay(currentUser.Role)</small>
                </span>
                <a href="my-submissions" class="btn btn-sm btn-outline-light me-2">👤 ЛК</a>
                <button @onclick="LogoutAsync" class="btn btn-sm btn-outline-light">🔒 Выход</button>
            }
            else
            {
                <a href="auth/login" class="btn btn-sm btn-outline-light">🔐 Вход</a>
            }
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Главная
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="contests">
                <span class="oi oi-list" aria-hidden="true"></span> 📺 Конкурсы
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="current-contest">
                <span class="oi oi-book" aria-hidden="true"></span> 📖 Текущий конкурс
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="hall-of-fame">
                <span class="oi oi-star" aria-hidden="true"></span> 🏆 Зал славы
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="contest/contest-1/discussion">
                <span class="oi oi-chat" aria-hidden="true"></span> 💬 Обсуждение
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="contest/contest-1/sorrow">
                <span class="oi oi-heart" aria-hidden="true"></span> 💔 Страсти по рифме
            </NavLink>
        </div>

        @if (currentUser?.Role >= UserRole.Author)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="current-contest">
                    <span class="oi oi-pencil" aria-hidden="true"></span> 📝 Подать работу
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="my-submissions">
                    <span class="oi oi-list" aria-hidden="true"></span> 📋 Мои работы
                </NavLink>
            </div>
        }

        @if (currentUser?.Role >= UserRole.Moderator)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="contests/opening">
                    <span class="oi oi-plus" aria-hidden="true"></span> 🚀 Открытие конкурса
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="moderation-queue">
                    <span class="oi oi-magnifying-glass" aria-hidden="true"></span> 🔍 Модерация
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="fair-voting-audit">
                    <span class="oi oi-spreadsheet" aria-hidden="true"></span> ⚖️ Аудит честного голосования
                </NavLink>
            </div>
        }

        @if (currentUser?.Role >= UserRole.Admin)
        {
            @if (currentUser?.Role == UserRole.Developer)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="role-management">
                        <span class="oi oi-people" aria-hidden="true"></span> 👨‍💻 Управление ролями
                    </NavLink>
                </div>
            }

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin-panel">
                    <span class="oi oi-task" aria-hidden="true"></span> 👨‍💼 Админ панель
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/violations">
                    <span class="oi oi-warning" aria-hidden="true"></span> 🎭 Нарушители (Зорро)
                </NavLink>
            </div>
        }

        <hr class="my-2" />

        @if (currentUser?.Role >= UserRole.Author)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="profile">
                    <span class="oi oi-person" aria-hidden="true"></span> 👤 Профиль
                </NavLink>
            </div>
        }

        @if (currentUser?.Role >= UserRole.Reader)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="voting">
                    <span class="oi oi-spreadsheet" aria-hidden="true"></span> 🗳 Голосование
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="results-summary">
                    <span class="oi oi-graph" aria-hidden="true"></span> 🏁 Подведение итогов
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="winners-announcement">
                    <span class="oi oi-star" aria-hidden="true"></span> 🏆 Объявление победителей
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="votes/import">
                    <span class="oi oi-cloud-upload" aria-hidden="true"></span> 📤 Импорт голосов
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private User? currentUser;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task LogoutAsync()
    {
        await AuthService.SetCurrentUserAsync(null);
        currentUser = null;
    }

    private string GetRoleBadgeClass(UserRole role) => role switch
    {
        UserRole.Reader => "bg-info",
        UserRole.Author => "bg-success",
        UserRole.Moderator => "bg-warning",
        UserRole.Admin => "bg-danger",
        UserRole.Developer => "bg-dark",
        _ => "bg-secondary"
    };

    private string GetRoleDisplay(UserRole role) => role switch
    {
        UserRole.Reader => "👤 Читатель",
        UserRole.Author => "✍️ Автор",
        UserRole.Moderator => "🔍 Модератор",
        UserRole.Admin => "👨‍💼 Admin",
        UserRole.Developer => "👨‍💻 Developer",
        _ => "?"
    };
}