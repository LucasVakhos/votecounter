@page "/fair-voting-audit"
@using Rhymers.Core.Models
@using Rhymers.Core.Services
@using Rhymers.Web.Services
@inject ContestService ContestService
@inject AuthorizationWebService AuthService

<div class="container mt-4">
    <h1>Аудит честного голосования</h1>
    <p class="text-muted">Сравнение человеческих оценок и системных автооценок FairVotingBot.</p>

    @if (currentUser == null)
    {
        <div class="alert alert-warning">Нужна авторизация.</div>
        return;
    }

    @if (currentUser.Role < UserRole.Moderator)
    {
        <div class="alert alert-danger">Доступно только модераторам и администраторам.</div>
        return;
    }

    @if (isLoading)
    {
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>
    }
    else if (contest == null)
    {
        <div class="alert alert-info">Текущий конкурс не найден.</div>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <h4 class="mb-1">@contest.Name</h4>
                <div class="text-muted">Конкурс №@contest.Number</div>
                <div class="mt-2 d-flex gap-2 flex-wrap">
                    <span class="badge text-bg-secondary">@ContestService.GetContestStageTitle(ContestService.GetContestStage(contest))</span>
                    <span class="badge @(contest.AutoFairVotingEnabled ? "text-bg-success" : "text-bg-warning")">
                        @(contest.AutoFairVotingEnabled ? "Честное голосование включено" : "Честное голосование выключено")
                    </span>
                </div>
            </div>
        </div>

        <div class="card mb-3 border-secondary-subtle">
            <div class="card-body">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Порог отклонения</label>
                        <input type="number" min="0" max="10" step="0.1" class="form-control" @bind="deviationThreshold" />
                        <div class="btn-group btn-group-sm mt-2" role="group" aria-label="Preset threshold buttons">
                            <button type="button" class="@GetThresholdPresetButtonClass(0.3m)" @onclick="() => SetThreshold(0.3m)">0.3</button>
                            <button type="button" class="@GetThresholdPresetButtonClass(0.5m)" @onclick="() => SetThreshold(0.5m)">0.5</button>
                            <button type="button" class="@GetThresholdPresetButtonClass(1.0m)" @onclick="() => SetThreshold(1.0m)">1.0</button>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="showOnlyDeviations" @bind="showOnlySignificantDeviations" />
                            <label class="form-check-label" for="showOnlyDeviations">
                                Показать только строки, где |разница| >= порога
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (visibleRows.Count == 0)
        {
            <div class="alert alert-secondary">Нет данных для аудита по текущему фильтру.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>№</th>
                            <th>Тема</th>
                            <th>Автор</th>
                            <th>Голосов людей</th>
                            <th>Средний (люди)</th>
                            <th>Честный бот</th>
                            <th>Админ-авто</th>
                            <th>Разница (честный)</th>
                            <th>Разница (админ)</th>
                            <th>Обновлено (честный)</th>
                            <th>Обновлено (админ)</th>
                            <th>Правило</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in visibleRows)
                        {
                            <tr>
                                <td>@row.DisplayNo</td>
                                <td>@row.Topic</td>
                                <td>@GetAuthorDisplay(row.Author)</td>
                                <td>@row.HumanVotesCount</td>
                                <td>@(row.HumanAverage.HasValue ? row.HumanAverage.Value.ToString("0.00") : "-")</td>
                                <td>@(row.FairSystemScore.HasValue ? row.FairSystemScore.Value.ToString() : "-")</td>
                                <td>@(row.AdminSystemScore.HasValue ? row.AdminSystemScore.Value.ToString() : "-")</td>
                                <td>
                                    @if (row.FairDelta.HasValue)
                                    {
                                        <span class="@GetDeltaClass(row.FairDelta.Value)">@row.FairDelta.Value.ToString("+0.00;-0.00;0.00")</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    @if (row.AdminDelta.HasValue)
                                    {
                                        <span class="@GetDeltaClass(row.AdminDelta.Value)">@row.AdminDelta.Value.ToString("+0.00;-0.00;0.00")</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@(row.FairSystemUpdatedAt.HasValue ? row.FairSystemUpdatedAt.Value.ToString("dd.MM.yyyy HH:mm") : "-")</td>
                                <td>@(row.AdminSystemUpdatedAt.HasValue ? row.AdminSystemUpdatedAt.Value.ToString("dd.MM.yyyy HH:mm") : "-")</td>
                                <td><small>@row.RuleLabel</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private User? currentUser;
    private Contest? contest;
    private List<FairVotingAuditRow> rows = new();
    private bool showOnlySignificantDeviations;
    private decimal deviationThreshold = 0.5m;
    private bool isLoading = true;

    private List<FairVotingAuditRow> visibleRows => BuildVisibleRows();

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser == null || currentUser.Role < UserRole.Moderator)
        {
            isLoading = false;
            return;
        }

        contest = await ContestService.GetCurrentContestAsync();
        if (contest == null)
        {
            isLoading = false;
            return;
        }

        var submissions = await ContestService.GetApprovedWorkSubmissionsAsync(contest.Id);
        var votes = await ContestService.GetContestVotesAsync(contest.Id);

        rows = FairVotingAuditCalculator.BuildRows(submissions, votes);
        isLoading = false;
    }

    private List<FairVotingAuditRow> BuildVisibleRows()
    {
        return FairVotingAuditCalculator.FilterByDeviation(rows, deviationThreshold, showOnlySignificantDeviations);
    }

    private void SetThreshold(decimal value)
    {
        deviationThreshold = value;
    }

    private string GetThresholdPresetButtonClass(decimal preset)
    {
        return Math.Abs(deviationThreshold - preset) < 0.01m
            ? "btn btn-secondary"
            : "btn btn-outline-secondary";
    }

    private string GetAuthorDisplay(string author)
    {
        if (contest == null)
            return "автор скрыт";

        var stage = ContestService.GetContestStage(contest);
        var canRevealAuthors = stage is ContestStage.VotingClosed or ContestStage.Finished;
        if (!canRevealAuthors)
            return "автор скрыт до объявления результатов";

        return string.IsNullOrWhiteSpace(author) ? "автор не указан" : author;
    }

    private static string GetDeltaClass(decimal delta)
    {
        if (delta > 0)
            return "text-success fw-semibold";
        if (delta < 0)
            return "text-danger fw-semibold";
        return "text-muted";
    }

}
