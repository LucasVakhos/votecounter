@page "/contests/opening"
@using Rhymers.Core.Models
@using Rhymers.Web.Services
@inject ContestService ContestService
@inject AuthorizationWebService AuthService

<div class="container mt-4">
    <h1>Открытие конкурса</h1>
    <p class="text-muted">Объявление, приём тем и приоритет тем победителей прошлого конкурса.</p>

    @if (currentUser == null)
    {
        <div class="alert alert-warning">Требуется вход в систему.</div>
        return;
    }

    @if (currentUser.Role < UserRole.Moderator)
    {
        <div class="alert alert-danger">Только модератор или администратор может открывать конкурс и принимать темы.</div>
        return;
    }

    <div class="card mb-3">
        <div class="card-body">
            <label class="form-label"><strong>Конкурс</strong></label>
            <select value="@selectedContestId" class="form-select" @onchange="OnContestChangedAsync">
                <option value="">-- выберите конкурс --</option>
                @foreach (var contest in contests)
                {
                    <option value="@contest.Id">@contest</option>
                }
            </select>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(selectedContestId) && selectedContest != null)
    {
        <div class="card mb-3">
            <div class="card-header">Разновидности тем</div>
            <div class="card-body">
                <div class="input-group mb-3">
                    <input class="form-control" @bind="newTopicKindName" placeholder="Новая разновидность" />
                    <button class="btn btn-outline-primary" @onclick="AddTopicKindAsync">Добавить</button>
                </div>

                @if (topicKinds.Count == 0)
                {
                    <div class="text-muted">Список разновидностей пока пуст.</div>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var kind in topicKinds)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @if (editingKindId == kind.Id)
                                {
                                    <div class="input-group me-2">
                                        <input class="form-control" @bind="editingKindName" />
                                        <button class="btn btn-success" @onclick="() => SaveTopicKindRenameAsync(kind.Id)">Сохранить</button>
                                        <button class="btn btn-outline-secondary" @onclick="CancelTopicKindEdit">Отмена</button>
                                    </div>
                                }
                                else
                                {
                                    <span>@kind.Name</span>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-secondary" @onclick="() => StartTopicKindEdit(kind)">Изменить</button>
                                        <button class="btn btn-outline-danger" @onclick="() => DeleteTopicKindAsync(kind.Id)">Удалить</button>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Настройки конкурса</div>
            <div class="card-body">
                <label class="form-label">Ограничение максимального количества тем</label>
                <input type="number" min="0" class="form-control" @bind="maxTopicsCount" />
                <div class="form-text">0 = без ограничения. После достижения лимита новые темы не принимаются.</div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Стадии конкурса</div>
            <div class="card-body">
                <div class="mb-2">
                    <strong>Текущая стадия:</strong>
                    <span class="badge text-bg-primary ms-2">@ContestService.GetContestStageTitle(ContestService.GetContestStage(selectedContest))</span>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-md-8">
                        <label class="form-label">Ручное переключение модератором</label>
                        <select class="form-select" @bind="manualStage">
                            @foreach (var stage in Enum.GetValues<ContestStage>())
                            {
                                <option value="@stage">@ContestService.GetContestStageTitle(stage)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button class="btn btn-outline-primary w-100" @onclick="ApplyManualStageAsync">Переключить стадию</button>
                    </div>
                </div>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" @bind="autoStageSwitchEnabled" id="autoStageSwitch" />
                    <label class="form-check-label" for="autoStageSwitch">Автоматическое переключение по времени</label>
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">До окончания приема тем</label>
                        <InputDate class="form-control" @bind-Value="topicReceptionEndsAt" Type="InputDateType.DateTimeLocal" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">До окончания приема работ</label>
                        <InputDate class="form-control" @bind-Value="workReceptionEndsAt" Type="InputDateType.DateTimeLocal" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">До окончания открытого голосования</label>
                        <InputDate class="form-control" @bind-Value="votingOpenEndsAt" Type="InputDateType.DateTimeLocal" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">До закрытия итоговой стадии</label>
                        <InputDate class="form-control" @bind-Value="votingClosedEndsAt" Type="InputDateType.DateTimeLocal" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Объявление о приёме тем</div>
            <div class="card-body">
                <textarea class="form-control" rows="5" @bind="announcementText"
                          placeholder="Добавьте текст объявления о начале приёма тем"></textarea>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-lg-6">
                <div class="card h-100 border-warning">
                    <div class="card-header bg-warning-subtle">Темы победителей прошлого конкурса (принимаются в первую очередь)</div>
                    <div class="card-body">
                        <label class="form-label">Разновидность для этих тем</label>
                        <select class="form-select mb-2" @bind="selectedWinnerTopicKindId">
                            <option value="">-- без разновидности --</option>
                            @foreach (var kind in topicKinds)
                            {
                                <option value="@kind.Id">@kind.Name</option>
                            }
                        </select>
                        <textarea class="form-control mb-2" rows="8" @bind="winnerTopicsText"
                                  placeholder="По одной теме на строку"></textarea>
                        <button class="btn btn-outline-warning btn-sm" @onclick="LoadWinnerSuggestionsAsync">Подтянуть из прошлого конкурса</button>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">Обычные подачи тем</div>
                    <div class="card-body">
                        <label class="form-label">Разновидность для этих тем</label>
                        <select class="form-select mb-2" @bind="selectedRegularTopicKindId">
                            <option value="">-- без разновидности --</option>
                            @foreach (var kind in topicKinds)
                            {
                                <option value="@kind.Id">@kind.Name</option>
                            }
                        </select>
                        <textarea class="form-control" rows="8" @bind="regularTopicsText"
                                  placeholder="По одной теме на строку"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-primary" @onclick="SaveOpeningAsync">Сохранить открытие конкурса</button>
            <button class="btn btn-outline-secondary" @onclick="ReloadTopicsAsync">Обновить список тем</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert @(isSuccess ? "alert-success" : "alert-danger") mt-3">@message</div>
        }

        <div class="card mt-3">
            <div class="card-header">Темы конкурса (@topics.Count)</div>
            <div class="card-body">
                @if (topics.Count == 0)
                {
                    <div class="text-muted">Пока нет ни одной темы.</div>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var topic in topics.OrderBy(t => t.Number))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <span><strong>@topic.Number.</strong> @topic.Title</span>
                                    @if (!string.IsNullOrWhiteSpace(GetTopicKindName(topic.TopicKindId)))
                                    {
                                        <span class="badge text-bg-info ms-2">@GetTopicKindName(topic.TopicKindId)</span>
                                    }
                                </div>
                                <div>
                                    @if (topic.IsWinnerTopic)
                                    {
                                        <span class="badge text-bg-warning">из тем победителей</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
</div>

@code {
    private User? currentUser;
    private List<Contest> contests = new();
    private Contest? selectedContest;
    private string selectedContestId = string.Empty;

    private int maxTopicsCount;
    private string announcementText = string.Empty;
    private string winnerTopicsText = string.Empty;
    private string regularTopicsText = string.Empty;
    private List<TopicKind> topicKinds = new();
    private int? selectedWinnerTopicKindId;
    private int? selectedRegularTopicKindId;
    private string newTopicKindName = string.Empty;
    private int? editingKindId;
    private string editingKindName = string.Empty;
    private ContestStage manualStage = ContestStage.TopicReception;
    private bool autoStageSwitchEnabled;
    private DateTime? topicReceptionEndsAt;
    private DateTime? workReceptionEndsAt;
    private DateTime? votingOpenEndsAt;
    private DateTime? votingClosedEndsAt;

    private List<ContestTopic> topics = new();
    private string message = string.Empty;
    private bool isSuccess;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        contests = (await ContestService.GetContestsAsync()).ToList();
        await ReloadTopicKindsAsync();
    }

    private async Task OnContestChangedAsync(ChangeEventArgs e)
    {
        selectedContestId = e.Value?.ToString() ?? string.Empty;
        await LoadContestContextAsync();
    }

    private async Task LoadContestContextAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedContestId))
        {
            selectedContest = null;
            topics.Clear();
            return;
        }

        selectedContest = await ContestService.GetContestAsync(selectedContestId);
        maxTopicsCount = selectedContest?.MaxTopicsCount ?? 0;
        manualStage = selectedContest == null ? ContestStage.TopicReception : ContestService.GetContestStage(selectedContest);
        autoStageSwitchEnabled = selectedContest?.AutoStageSwitchEnabled ?? false;
        topicReceptionEndsAt = selectedContest?.TopicReceptionEndsAt;
        workReceptionEndsAt = selectedContest?.WorkReceptionEndsAt;
        votingOpenEndsAt = selectedContest?.VotingOpenEndsAt;
        votingClosedEndsAt = selectedContest?.VotingClosedEndsAt;
        announcementText = BuildAnnouncement(selectedContest);
        await ReloadTopicKindsAsync();
        await ReloadTopicsAsync();
    }

    private async Task ReloadTopicKindsAsync()
    {
        topicKinds = await ContestService.GetTopicKindsAsync();

        if (topicKinds.Count > 0)
        {
            selectedWinnerTopicKindId ??= topicKinds[0].Id;
            selectedRegularTopicKindId ??= topicKinds[0].Id;
        }
    }

    private async Task AddTopicKindAsync()
    {
        var added = await ContestService.AddTopicKindAsync(newTopicKindName);
        if (added == null)
        {
            message = "Не удалось добавить разновидность: пустое имя или дубль.";
            isSuccess = false;
            return;
        }

        newTopicKindName = string.Empty;
        await ReloadTopicKindsAsync();
        message = "Разновидность добавлена.";
        isSuccess = true;
    }

    private void StartTopicKindEdit(TopicKind kind)
    {
        editingKindId = kind.Id;
        editingKindName = kind.Name;
    }

    private void CancelTopicKindEdit()
    {
        editingKindId = null;
        editingKindName = string.Empty;
    }

    private async Task SaveTopicKindRenameAsync(int kindId)
    {
        var renamed = await ContestService.RenameTopicKindAsync(kindId, editingKindName);
        if (!renamed)
        {
            message = "Не удалось переименовать разновидность: пустое имя или дубль.";
            isSuccess = false;
            return;
        }

        CancelTopicKindEdit();
        await ReloadTopicKindsAsync();
        message = "Разновидность обновлена.";
        isSuccess = true;
    }

    private async Task DeleteTopicKindAsync(int kindId)
    {
        var (success, error) = await ContestService.DeleteTopicKindAsync(kindId);
        if (!success)
        {
            message = error;
            isSuccess = false;
            return;
        }

        if (selectedWinnerTopicKindId == kindId)
            selectedWinnerTopicKindId = null;
        if (selectedRegularTopicKindId == kindId)
            selectedRegularTopicKindId = null;

        await ReloadTopicKindsAsync();
        message = "Разновидность удалена.";
        isSuccess = true;
    }

    private async Task ReloadTopicsAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedContestId))
            return;

        topics = await ContestService.GetContestTopicsAsync(selectedContestId);
        StateHasChanged();
    }

    private async Task LoadWinnerSuggestionsAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedContestId))
            return;

        var suggestions = await ContestService.GetPreviousContestWinnerTopicSuggestionsAsync(selectedContestId);
        if (suggestions.Count == 0)
        {
            message = "Не удалось найти темы прошлого конкурса для подсказки.";
            isSuccess = false;
            return;
        }

        winnerTopicsText = string.Join(Environment.NewLine, suggestions);
        message = $"Подтянуто {suggestions.Count} тем из прошлого конкурса.";
        isSuccess = true;
    }

    private async Task SaveOpeningAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedContestId) || selectedContest == null)
            return;

        var winnerTopics = ParseLines(winnerTopicsText);
        var regularTopics = ParseLines(regularTopicsText);

        await ContestService.SaveMaxTopicsCountAsync(selectedContestId, maxTopicsCount);
        await ContestService.SaveStageAutomationSettingsAsync(
            selectedContestId,
            autoStageSwitchEnabled,
            topicReceptionEndsAt,
            workReceptionEndsAt,
            votingOpenEndsAt,
            votingClosedEndsAt);

        var proposedBy = string.IsNullOrWhiteSpace(currentUser?.DisplayName)
            ? currentUser?.Username ?? "system"
            : currentUser!.DisplayName;

        var (addedWinner, addedRegular, skipped) = await ContestService.AddTopicsWithPriorityAsync(
            selectedContestId,
            winnerTopics,
            regularTopics,
            proposedBy,
            selectedWinnerTopicKindId,
            selectedRegularTopicKindId);

        await ReloadTopicsAsync();

        message = $"Сохранено. Объявление подготовлено. Добавлено тем победителей: {addedWinner}, обычных тем: {addedRegular}, пропущено: {skipped}.";
        isSuccess = true;
    }

    private async Task ApplyManualStageAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedContestId))
            return;

        var changed = await ContestService.SetContestStageAsync(selectedContestId, manualStage);
        if (!changed)
        {
            message = "Не удалось переключить стадию конкурса.";
            isSuccess = false;
            return;
        }

        selectedContest = await ContestService.GetContestAsync(selectedContestId);
        message = $"Стадия изменена: {ContestService.GetContestStageTitle(manualStage)}.";
        isSuccess = true;
    }

    private static List<string> ParseLines(string text)
    {
        return text
            .Replace("\r\n", "\n")
            .Replace('\r', '\n')
            .Split('\n', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => x.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static string BuildAnnouncement(Contest? contest)
    {
        if (contest == null)
            return string.Empty;

        var header = string.IsNullOrWhiteSpace(contest.Number)
            ? $"Открыт приём тем в конкурсе «{contest.Name}»."
            : $"Открыт приём тем в конкурсе №{contest.Number} «{contest.Name}».";

        return header + Environment.NewLine +
               "В первую очередь принимаются темы победителей прошлого конкурса." + Environment.NewLine +
               "Подавайте темы по одной строке.";
    }

    private string GetTopicKindName(int? kindId)
    {
        if (!kindId.HasValue)
            return string.Empty;

        var kind = topicKinds.FirstOrDefault(k => k.Id == kindId.Value);
        return kind?.Name ?? string.Empty;
    }
}
