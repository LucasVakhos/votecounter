@page "/contest/{ContestId}/sorrow"
@using Rhymers.Web.Services
@using Rhymers.Core.Models
@inject SorrowChatWebService SorrowService
@inject DiscussionService DiscussionService
@inject AuthorizationWebService AuthService
@inject ContestService ContestService
@inject AppealWebService AppealService
@inject NavigationManager NavigationManager

@{
    var contestId = ContestId ?? "contest-1";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1>💔 Страсти по рифме</h1>
            <p class="text-muted">Поделитесь своими переживаниями, впечатлениями и размышлениями о конкурсе</p>

            <div class="alert alert-info" role="alert">
                <strong>📋 Правила чата:</strong>
                <ul class="mb-0" style="font-size: 0.95em;">
                    <li>✅ <strong>Спорить можно и нужно</strong> — конструктивная критика и разные мнения приветствуются</li>
                    <li>❌ <strong>Хамить нельзя</strong> — грубость, оскорбления и мат запрещены</li>
                    <li>❌ <strong>Троллить нельзя</strong> — провокации и намеренные оскорбления приведут к блокировке</li>
                </ul>
            </div>

            @if (currentUser == null)
            {
                <div class="alert alert-warning" role="alert">
                    <strong>⚠️ Требуется вход!</strong> 
                    <a href="/auth/login" class="alert-link">Войдите в систему</a> чтобы участвовать в чате.
                </div>
                return;
            }

            @if (userViolationStats?.IsSanctioned ?? false)
            {
                <div class="card mb-4 border-warning">
                    <div class="card-header bg-warning text-dark">
                        <strong>⏱️ Вы временно ограничены в доступе к чату</strong>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning mb-3" role="alert">
                            @if (userViolationStats.CurrentSanction == SanctionType.OneDay)
                            {
                                <span>⚠️ Санкция на 1 день</span>
                            }
                            else if (userViolationStats.CurrentSanction == SanctionType.OneWeek)
                            {
                                <span>⚠️ Санкция на 7 дней</span>
                            }
                            else if (userViolationStats.CurrentSanction == SanctionType.OneMonth)
                            {
                                <span>⚠️ Санкция на 30 дней</span>
                            }
                            else if (userViolationStats.CurrentSanction == SanctionType.Permanent)
                            {
                                <span>🚫 Постоянная блокировка</span>
                            }
                            @if (!string.IsNullOrEmpty(userViolationStats.SanctionReason))
                            {
                                <br><small>Причина: @userViolationStats.SanctionReason</small>
                            }
                        </div>

                        <div class="alert alert-info" role="alert">
                            <h5 class="mb-2">⏳ Время до разблокировки:</h5>
                            <h3 style="color: #d9534f; font-family: monospace;">@sanctionCountdown</h3>
                            <small class="text-muted">Форма ввода недоступна на время санкции</small>
                        </div>

                        <form>
                            <div class="mb-3">
                                <label for="sanctionType" class="form-label">Тип переживания</label>
                                <select id="sanctionType" class="form-select form-select-sm" disabled>
                                    <option selected>🤔 Размышление</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="sanctionContent" class="form-label">Что вас волнует?</label>
                                <textarea id="sanctionContent" class="form-control" rows="4"
                                          placeholder="❌ Форма недоступна до конца санкции..." disabled
                                          style="resize: vertical;"></textarea>
                                <small class="form-text text-muted">Максимум 2000 символов</small>
                            </div>

                            <div class="d-flex justify-content-between">
                                <button type="submit" class="btn btn-primary" disabled>
                                    💬 Поделиться
                                </button>
                            </div>
                        </form>

                        <!-- Кнопка подачи жалобы -->
                        <hr />
                        @if (!showAppealForm)
                        {
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => showAppealForm = true">
                                🙏 Считаете санкцию несправедливой? Подать жалобу
                            </button>
                        }
                        else
                        {
                            <div class="mt-2">
                                <h6>📝 Жалоба на санкцию</h6>
                                <textarea class="form-control mb-2" rows="3"
                                          placeholder="Объясните, почему считаете санкцию несправедливой..."
                                          @bind="appealReason"></textarea>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-warning" @onclick="SubmitAppealAsync" disabled="@submittingAppeal">
                                        @if (submittingAppeal) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        🙏 Отправить жалобу
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => showAppealForm = false">Отмена</button>
                                </div>
                                @if (!string.IsNullOrEmpty(appealMessage))
                                {
                                    <div class="alert @(appealSuccess ? "alert-success" : "alert-danger") mt-2 py-1">@appealMessage</div>
                                }
                            </div>
                        }
                    </div>
                </div>
                return;
            }

            @if (userViolationStats?.IsBlocked ?? false)
            {
                <div class="alert alert-danger" role="alert">
                    <strong>⛔ Вы заблокированы в этом чате</strong><br>
                    @userViolationStats.BlockReason<br>
                    <small>Обратитесь к модератору для разблокировки</small>
                </div>
                return;
            }

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <strong>✍️ Поделиться переживанием</strong>
                </div>
                <div class="card-body">
                    <form @onsubmit="AddMessageAsync">
                        <div class="mb-3">
                            <label for="sorrowType" class="form-label">Тип переживания</label>
                            <select @bind="newMessage.Type" id="sorrowType" class="form-select form-select-sm">
                                <option value="@SorrowType.Reflection">🤔 Размышление</option>
                                <option value="@SorrowType.Fear">😰 Страх, волнение</option>
                                <option value="@SorrowType.Disappointment">😢 Разочарование</option>
                                <option value="@SorrowType.Inspiration">✨ Вдохновение</option>
                                <option value="@SorrowType.Support">🤝 Поддержка</option>
                                <option value="@SorrowType.SelfAnalysis">🔍 Анализ своей работы</option>
                                <option value="@SorrowType.Impressions">👀 Впечатления</option>
                                <option value="@SorrowType.LifeCircumstances">🌍 Жизненные обстоятельства</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="content" class="form-label">Что вас волнует? *</label>
                            <textarea @bind="newMessage.Content" id="content" class="form-control" rows="4"
                                      placeholder="Поделитесь своими мыслями и чувствами..." required
                                      style="resize: vertical;"></textarea>
                            <small class="form-text text-muted">Максимум 2000 символов</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Отправка...</span>
                                }
                                else
                                {
                                    <span>💬 Поделиться</span>
                                }
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert @(isSuccess ? "alert-success" : "alert-danger") mt-3" role="alert">
                                @message
                            </div>
                        }
                    </form>
                </div>
            </div>

            @if (stats != null)
            {
                <div class="row mb-3">
                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">💬</h5>
                                <p class="card-text">@stats.ApprovedMessages сообщений</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">❤️</h5>
                                <p class="card-text">@stats.TotalEmpathy поддержек</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">👥</h5>
                                <p class="card-text">@GetUniqueAuthorsCount() участников</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">⏱️</h5>
                                <p class="card-text">Живой чат</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <h3 class="mt-5">💭 Обсуждение переживаний</h3>
            
            @if (messages == null || messages.Count == 0)
            {
                <div class="alert alert-info" role="alert">
                    <strong>🤐 Тишина...</strong> Пока никто не поделился своими переживаниями. Вы можете быть первым!
                </div>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    @if (msg.AuthorName == "Администрация")
                    {
                        <!-- Объявление администрации -->
                        <div class="alert alert-danger border-3 mb-3" role="alert">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="alert-heading mb-2">
                                        ⚖️ <strong>ОБЪЯВЛЕНИЕ АДМИНИСТРАЦИИ</strong>
                                    </h6>
                                    <p class="mb-2">@msg.Content</p>
                                    <small class="text-muted">@GetTimeDisplay(msg.CreatedAt)</small>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h6 class="card-subtitle mb-1">
                                            <strong>@msg.AuthorName</strong>
                                            <span class="badge @GetRoleBadgeClass(msg.AuthorRole)">@GetRoleDisplay(msg.AuthorRole)</span>
                                        </h6>
                                        <small class="text-muted">@GetSorrowTypeEmoji(msg.Type) @msg.Type.ToString()</small>
                                    </div>
                                    <small class="text-muted">@GetTimeDisplay(msg.CreatedAt)</small>
                                </div>

                                <p class="card-text">@msg.Content</p>

                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <button class="btn btn-sm btn-outline-heart" @onclick="async () => await AddEmpathyAsync(msg.Id)">
                                    ❤️ @msg.EmpathyCount
                                </button>
                                
                                @{
                                    var replyCount = messageReplies.TryGetValue(msg.Id, out var replies) ? replies.Count : 0;
                                }
                                
                                @if (replyCount > 0 || expandedDiscussionMessageId == msg.Id || expandedReplyFormMessageId == msg.Id)
                                {
                                    <button class="btn btn-sm btn-outline-info" @onclick="async () => await ToggleRepliesAsync(msg.Id)">
                                        📖 Дискуссия (@replyCount)
                                    </button>
                                }
                                
                                <button class="btn btn-sm btn-outline-secondary" @onclick="async () => await ToggleReplyFormAsync(msg.Id)">
                                    💬 Ответить
                                </button>

                                @if (currentUser != null && currentUser.Role >= UserRole.Moderator)
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="async () => await ApproveAsync(msg.Id)" disabled="@msg.IsApproved">
                                        ✓ Одобрить
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="async () => await HideAsync(msg.Id)" disabled="@msg.IsHidden">
                                        🚫 Скрыть
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleViolationForm(msg.Id)">
                                        🚩 Хамство
                                    </button>
                                }
                            </div>

                            @if (currentUser != null && currentUser.Role >= UserRole.Moderator && expandedViolationMessageId == msg.Id)
                            {
                                <div class="card card-body mt-2" style="background-color: #fff3cd;">
                                    <h6>Классификация нарушения:</h6>
                                    <div class="mb-3">
                                        <select class="form-select form-select-sm" @onchange="e => selectedViolationType[msg.Id] = (ViolationType)int.Parse(e.Value?.ToString() ?? string.Empty)">
                                            <option value="0">🤬 Грубость/мат/оскорбления</option>
                                            <option value="1">🎣 Троллинг/провокации</option>
                                            <option value="2">📢 Спам/флуд</option>
                                            <option value="3">⚠️ Другое нарушение</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <textarea class="form-control form-control-sm" placeholder="Комментарий модератора (опционально)" rows="2" @onchange="e => violationDetails[msg.Id] = e.Value?.ToString() ?? string.Empty"></textarea>
                                    </div>

                                    @if (currentUser?.Role >= UserRole.Admin)
                                    {
                                        <hr>
                                        <h6 style="color: #dc3545;">⚖️ Санкция (только администраторы):</h6>
                                        <div class="mb-3">
                                            <div class="btn-group w-100" role="group">
                                                <input type="radio" class="btn-check" name="sanction_@msg.Id" id="sanction_none_@msg.Id" autocomplete="off" @onchange="e => selectedSanction[msg.Id] = SanctionType.None" />
                                                <label class="btn btn-outline-secondary btn-sm" for="sanction_none_@msg.Id">Нет</label>

                                                <input type="radio" class="btn-check" name="sanction_@msg.Id" id="sanction_1day_@msg.Id" autocomplete="off" @onchange="e => selectedSanction[msg.Id] = SanctionType.OneDay" />
                                                <label class="btn btn-outline-warning btn-sm" for="sanction_1day_@msg.Id">1 день</label>

                                                <input type="radio" class="btn-check" name="sanction_@msg.Id" id="sanction_1week_@msg.Id" autocomplete="off" @onchange="e => selectedSanction[msg.Id] = SanctionType.OneWeek" />
                                                <label class="btn btn-outline-warning btn-sm" for="sanction_1week_@msg.Id">7 дней</label>

                                                <input type="radio" class="btn-check" name="sanction_@msg.Id" id="sanction_1month_@msg.Id" autocomplete="off" @onchange="e => selectedSanction[msg.Id] = SanctionType.OneMonth" />
                                                <label class="btn btn-outline-danger btn-sm" for="sanction_1month_@msg.Id">30 дней</label>

                                                <input type="radio" class="btn-check" name="sanction_@msg.Id" id="sanction_perm_@msg.Id" autocomplete="off" @onchange="e => selectedSanction[msg.Id] = SanctionType.Permanent" />
                                                <label class="btn btn-outline-danger btn-sm" for="sanction_perm_@msg.Id">♾️ Навсегда</label>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <textarea class="form-control form-control-sm" placeholder="Причина санкции (опционально)" rows="2" @onchange="e => sanctionReasons[msg.Id] = e.Value?.ToString() ?? string.Empty"></textarea>
                                        </div>
                                    }

                                    <div>
                                        <button class="btn btn-sm btn-danger" @onclick="async () => await MarkAsViolationAsync(msg.Id)" disabled="@markingAsViolation.GetValueOrDefault(msg.Id)">
                                            @if (markingAsViolation.GetValueOrDefault(msg.Id))
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                            }
                                            💾 Зафиксировать нарушение
                                        </button>
                                        <button class="btn btn-sm btn-secondary" @onclick="() => ToggleViolationForm(msg.Id)">
                                            ✕ Отменить
                                        </button>
                                    </div>
                                </div>
                            }

                            @if (msg.EmpathyCount > 0)
                            {
                                <small class="text-muted d-block mt-2">Поддержало @msg.EmpathyCount человек(а)</small>
                            }

                            @if (expandedDiscussionMessageId == msg.Id)
                            {
                                @if (messageReplies.TryGetValue(msg.Id, out var discussionReplies) && discussionReplies.Count > 0)
                                {
                                    <div class="mt-3">
                                        <h6 class="mb-2" style="color: #666;">📖 Дискуссия (@discussionReplies.Count):</h6>
                                        @foreach (var reply in discussionReplies.OrderBy(r => r.CreatedAt))
                                        {
                                            <div class="card mb-2" style="margin-left: 20px; border-left: 3px solid #007bff;">
                                                <div class="card-body py-2">
                                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                                        <div>
                                                            <small><strong>@reply.AuthorName</strong></small>
                                                            <span class="badge @GetRoleBadgeClass(reply.AuthorRole)" style="font-size: 0.7em; margin-left: 5px;">@GetRoleDisplay(reply.AuthorRole)</span>
                                                        </div>
                                                        <small class="text-muted">@GetTimeDisplay(reply.CreatedAt)</small>
                                                    </div>
                                                    <p class="mb-1 small">@reply.Content</p>
                                                    <div>
                                                        <button class="btn btn-sm btn-outline-heart" @onclick="async () => await AddEmpathyAsync(reply.Id)" style="padding: 2px 8px; font-size: 0.85em;">
                                                            ❤️ @reply.EmpathyCount
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-secondary mt-3 mb-0" style="font-size: 0.9em;">
                                        Нет ответов на это сообщение
                                    </div>
                                }
                            }

                            @if (expandedReplyFormMessageId == msg.Id)
                            {
                                <div class="card mt-3 bg-light">
                                    <div class="card-body">
                                        <h6 class="mb-3">Ответить на сообщение</h6>
                                        @{
                                            if (!replyTexts.ContainsKey(msg.Id))
                                                replyTexts[msg.Id] = "";
                                            var currentReplyText = replyTexts[msg.Id];
                                        }
                                        <form @onsubmit="async () => await AddReplyAsync(msg.Id)">
                                            <textarea class="form-control form-control-sm mb-2" rows="2"
                                                      placeholder="Ваш ответ..." required
                                                      @onchange="@((ChangeEventArgs e) => { replyTexts[msg.Id] = e.Value?.ToString() ?? string.Empty; })"
                                                      value="@currentReplyText"
                                                      style="resize: vertical;"></textarea>
                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-sm btn-primary" disabled="@replySubmitting.GetValueOrDefault(msg.Id)">
                                                    @if (replySubmitting.GetValueOrDefault(msg.Id))
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                        <span>Отправка...</span>
                                                    }
                                                    else
                                                    {
                                                        <span>✓ Ответить</span>
                                                    }
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="async () => await ToggleReplyFormAsync(msg.Id)">
                                                    ✕ Отмена
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                @if (messageReplies.TryGetValue(msg.Id, out var formReplies) && formReplies.Count > 0)
                                {
                                    <div class="mt-3">
                                        <h6 class="mb-2" style="color: #666;">Ответы:</h6>
                                        @foreach (var reply in formReplies.OrderBy(r => r.CreatedAt))
                                        {
                                            <div class="card mb-2" style="margin-left: 20px; border-left: 3px solid #007bff;">
                                                <div class="card-body py-2">
                                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                                        <div>
                                                            <small><strong>@reply.AuthorName</strong></small>
                                                            <span class="badge @GetRoleBadgeClass(reply.AuthorRole)" style="font-size: 0.7em; margin-left: 5px;">@GetRoleDisplay(reply.AuthorRole)</span>
                                                        </div>
                                                        <small class="text-muted">@GetTimeDisplay(reply.CreatedAt)</small>
                                                    </div>
                                                    <p class="mb-1 small">@reply.Content</p>
                                                    <div>
                                                        <button class="btn btn-sm btn-outline-heart" @onclick="async () => await AddEmpathyAsync(reply.Id)" style="padding: 2px 8px; font-size: 0.85em;">
                                                            ❤️ @reply.EmpathyCount
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>                    }                }
            }

            <h3 class="mt-5">📝 Рецензии на работы</h3>
            
            @if (contestReviews == null || contestReviews.Count == 0)
            {
                <div class="alert alert-secondary" role="alert">
                    <strong>📭 Рецензий еще нет</strong> Рецензии появятся здесь после отправки модератором
                </div>
            }
            else
            {
                @foreach (var workGroup in contestReviews.GroupBy(r => r.WorkNumber).OrderBy(g => g.Key))
                {
                    <div class="card mb-3 border-start border-primary border-3">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">📖 Работа №@workGroup.Key: @workGroup.First().WorkTitle</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var review in workGroup.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="mb-3 pb-3 border-bottom" style="@(review == workGroup.Last() ? "border-bottom: none !important;" : "")">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div>
                                            <strong>@review.ReviewerName</strong>
                                            <span class="badge @GetRoleBadgeClass(review.ReviewerRole)" style="margin-left: 5px;">@GetRoleDisplay(review.ReviewerRole)</span>
                                        </div>
                                        @if (review.Rating.HasValue)
                                        {
                                            <div class="text-warning">
                                                @for (int i = 0; i < review.Rating; i++)
                                                {
                                                    <span>⭐</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                    <h6 class="mt-2">@review.Title</h6>
                                    <p class="text-muted mb-2">@review.Content</p>
                                    @if (!string.IsNullOrEmpty(review.Strengths))
                                    {
                                        <p class="mb-1">
                                            <small class="text-success"><strong>✓ Достоинства:</strong> @review.Strengths</small>
                                        </p>
                                    }
                                    @if (!string.IsNullOrEmpty(review.AreasForImprovement))
                                    {
                                        <p class="mb-1">
                                            <small class="text-warning"><strong>→ На улучшение:</strong> @review.AreasForImprovement</small>
                                        </p>
                                    }
                                    <small class="text-muted d-block">@review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    .btn-outline-heart:hover {
        color: #dc3545;
        border-color: #dc3545;
        background-color: transparent;
    }
</style>

@code {
    [Parameter]
    public string? ContestId { get; set; }

    private User? currentUser;
    private List<ContestSorrowMessage> messages = new();
    private List<WorkReview> contestReviews = new();
    private SorrowChatStatsDto? stats;
    private AddSorrowMessageRequest newMessage = new();
    private string message = "";
    private bool isSuccess = false;
    private bool isSubmitting = false;
    private UserViolationStats? userViolationStats;
    private string sanctionCountdown = string.Empty;
    private System.Timers.Timer? sanctionTimer;

    // Appeal state
    private bool showAppealForm = false;
    private string appealReason = string.Empty;
    private string appealMessage = string.Empty;
    private bool appealSuccess = false;
    private bool submittingAppeal = false;
    
    // Reply system state
    private string? expandedDiscussionMessageId = null;
    private string? expandedReplyFormMessageId = null;
    private Dictionary<string, List<ContestSorrowMessage>> messageReplies = new();
    private Dictionary<string, string> replyTexts = new();
    private Dictionary<string, bool> replySubmitting = new();
    
    // HamFilter state
    private string? expandedViolationMessageId = null;
    private Dictionary<string, ViolationType> selectedViolationType = new();
    private Dictionary<string, string> violationDetails = new();
    private Dictionary<string, bool> markingAsViolation = new();
    
    // Sanction system state
    private Dictionary<string, SanctionType> selectedSanction = new();
    private Dictionary<string, string> sanctionReasons = new();
    private Dictionary<string, bool> applyingSanction = new();

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        var contestId = ContestId ?? "contest-1";
        
        await LoadMessagesAsync(contestId);
        await LoadReviewsAsync(contestId);
        await LoadStatsAsync(contestId);
        await LoadUserViolationStatsAsync(contestId);
    }

    private async Task LoadReviewsAsync(string contestId)
    {
        try
        {
            contestReviews = await DiscussionService.GetContestReviewsAsync(contestId);
        }
        catch (Exception ex)
        {
            // Ignore review loading errors
        }
    }

    private async Task LoadMessagesAsync(string contestId)
    {
        try
        {
            messages = await SorrowService.GetApprovedSorrowMessagesAsync(contestId);
        }
        catch (Exception ex)
        {
            message = $"Ошибка при загрузке сообщений: {ex.Message}";
            isSuccess = false;
        }
    }

    private async Task LoadStatsAsync(string contestId)
    {
        try
        {
            stats = await SorrowService.GetChatStatsAsync(contestId);
        }
        catch (Exception ex)
        {
            // Ignore stats loading errors
        }
    }

    private async Task AddMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(newMessage.Content) || currentUser == null)
            return;

        try
        {
            isSubmitting = true;
            var contestId = ContestId ?? "contest-1";
            await SorrowService.AddSorrowMessageAsync(contestId, newMessage);

            message = "✅ Спасибо за ваше переживание! Модератор его проверит.";
            isSuccess = true;

            newMessage = new();
            await LoadMessagesAsync(contestId);
            await LoadStatsAsync(contestId);

            await Task.Delay(2000);
            message = "";
        }
        catch (Exception ex)
        {
            message = $"❌ Ошибка: {ex.Message}";
            isSuccess = false;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task AddEmpathyAsync(string messageId)
    {
        try
        {
            await SorrowService.AddEmpathyAsync(messageId);
            var contestId = ContestId ?? "contest-1";
            await LoadMessagesAsync(contestId);
            await LoadStatsAsync(contestId);
        }
        catch (Exception ex)
        {
            message = $"Ошибка: {ex.Message}";
        }
    }

    private async Task ApproveAsync(string messageId)
    {
        try
        {
            await SorrowService.ApproveSorrowMessageAsync(messageId);
            var contestId = ContestId ?? "contest-1";
            await LoadMessagesAsync(contestId);
        }
        catch (Exception ex)
        {
            message = $"Ошибка при одобрении: {ex.Message}";
        }
    }

    private async Task HideAsync(string messageId)
    {
        try
        {
            await SorrowService.HideSorrowMessageAsync(messageId);
            var contestId = ContestId ?? "contest-1";
            await LoadMessagesAsync(contestId);
        }
        catch (Exception ex)
        {
            message = $"Ошибка при скрытии: {ex.Message}";
        }
    }

    private string GetSorrowTypeEmoji(SorrowType type) => type switch
    {
        SorrowType.Reflection => "🤔",
        SorrowType.Fear => "😰",
        SorrowType.Disappointment => "😢",
        SorrowType.Inspiration => "✨",
        SorrowType.Support => "🤝",
        SorrowType.SelfAnalysis => "🔍",
        SorrowType.Impressions => "👀",
        SorrowType.LifeCircumstances => "🌍",
        _ => "💭"
    };

    private string GetRoleDisplay(UserRole role) => role switch
    {
        UserRole.Reader => "👤 Читатель",
        UserRole.Author => "✍️ Автор",
        UserRole.Moderator => "👮 Модератор",
        UserRole.Admin => "👑 Админ",
        _ => "Участник"
    };

    private string GetRoleBadgeClass(UserRole role) => role switch
    {
        UserRole.Admin => "bg-danger",
        UserRole.Moderator => "bg-warning",
        UserRole.Author => "bg-info",
        _ => "bg-secondary"
    };

    private string GetTimeDisplay(DateTime time)
    {
        var diff = DateTime.Now - time;
        if (diff.TotalMinutes < 1)
            return "только что";
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes}м назад";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours}ч назад";
        return time.ToString("dd.MM.yyyy");
    }

    private int GetUniqueAuthorsCount()
    {
        return messages.Select(m => m.AuthorName).Distinct().Count();
    }

    private async Task ToggleRepliesAsync(string messageId)
    {
        if (expandedDiscussionMessageId == messageId)
        {
            expandedDiscussionMessageId = null;
        }
        else
        {
            expandedDiscussionMessageId = messageId;
            if (!messageReplies.ContainsKey(messageId))
            {
                await LoadMessageRepliesAsync(messageId);
            }
        }
    }

    private async Task ToggleReplyFormAsync(string messageId)
    {
        if (expandedReplyFormMessageId == messageId)
        {
            expandedReplyFormMessageId = null;
        }
        else
        {
            expandedReplyFormMessageId = messageId;
            if (!messageReplies.ContainsKey(messageId))
            {
                await LoadMessageRepliesAsync(messageId);
            }
        }
    }

    private async Task LoadMessageRepliesAsync(string messageId)
    {
        try
        {
            var replies = await SorrowService.GetMessageRepliesAsync(messageId);
            messageReplies[messageId] = replies;
        }
        catch (Exception ex)
        {
            message = $"Ошибка при загрузке ответов: {ex.Message}";
        }
    }

    private async Task AddReplyAsync(string parentMessageId)
    {
        if (string.IsNullOrWhiteSpace(replyTexts.GetValueOrDefault(parentMessageId)) || currentUser == null)
            return;

        try
        {
            replySubmitting[parentMessageId] = true;
            var contestId = ContestId ?? "contest-1";

            var replyMessage = new AddSorrowMessageRequest
            {
                Content = replyTexts[parentMessageId],
                Type = SorrowType.Reflection,
                ParentMessageId = parentMessageId
            };

            await SorrowService.AddSorrowMessageAsync(contestId, replyMessage);

            replyTexts[parentMessageId] = "";
            await LoadMessageRepliesAsync(parentMessageId);
        }
        catch (Exception ex)
        {
            message = $"❌ Ошибка при отправке ответа: {ex.Message}";
        }
        finally
        {
            replySubmitting[parentMessageId] = false;
        }
    }

    // HamFilter methods
    private void ToggleViolationForm(string messageId)
    {
        if (expandedViolationMessageId == messageId)
        {
            expandedViolationMessageId = null;
        }
        else
        {
            expandedViolationMessageId = messageId;
            if (!selectedViolationType.ContainsKey(messageId))
                selectedViolationType[messageId] = ViolationType.Rudeness;
            if (!violationDetails.ContainsKey(messageId))
                violationDetails[messageId] = "";
        }
    }

    private async Task MarkAsViolationAsync(string messageId)
    {
        if (currentUser?.Role < UserRole.Moderator) return;
        if (!selectedViolationType.ContainsKey(messageId)) return;

        try
        {
            markingAsViolation[messageId] = true;
            var contestId = ContestId ?? "contest-1";
            var violationType = selectedViolationType[messageId];
            var details = violationDetails.GetValueOrDefault(messageId, "");

            var violation = await SorrowService.MarkAsViolationAsync(contestId, messageId, currentUser.DisplayName, violationType, details);

            // Если администратор выбрал санкцию, применяем её
            if (currentUser.Role >= UserRole.Admin && selectedSanction.TryGetValue(messageId, out var sanctionType) && sanctionType != SanctionType.None)
            {
                var sanctionReason = sanctionReasons.GetValueOrDefault(messageId, "");
                await SorrowService.ApplySanctionAsync(violation.Id, sanctionType, currentUser.DisplayName, sanctionReason);
                
                // Отправляем объявление в чат
                await SorrowService.PostSanctionAnnouncementAsync(contestId, violation.UserName, sanctionType, sanctionReason);
                
                message = $"✅ Нарушение зафиксировано. Санкция применена: {GetSanctionDisplay(sanctionType)}";
            }
            else
            {
                message = "✅ Нарушение зафиксировано и учтено в профиле пользователя";
            }
            
            isSuccess = true;
            
            expandedViolationMessageId = null;
            selectedViolationType.Remove(messageId);
            violationDetails.Remove(messageId);
            selectedSanction.Remove(messageId);
            sanctionReasons.Remove(messageId);

            // Перезагрузим сообщения и статистику
            await LoadMessagesAsync(contestId);
            await LoadUserViolationStatsAsync(contestId);
            
            await Task.Delay(3000);
            message = "";
        }
        catch (Exception ex)
        {
            message = $"❌ Ошибка: {ex.Message}";
            isSuccess = false;
        }
        finally
        {
            markingAsViolation[messageId] = false;
        }
    }

    private string GetSanctionDisplay(SanctionType type) => type switch
    {
        SanctionType.OneDay => "⏰ На 1 день",
        SanctionType.OneWeek => "📅 На 7 дней",
        SanctionType.OneMonth => "🗓️ На 30 дней",
        SanctionType.Permanent => "♾️ Постоянно",
        _ => "Нет"
    };

    private async Task LoadUserViolationStatsAsync(string contestId)
    {
        if (currentUser == null) return;

        try
        {
            userViolationStats = await SorrowService.GetUserViolationStatsAsync(contestId, currentUser.DisplayName);
            
            // Запустить таймер если есть активная санкция
            if (userViolationStats?.IsSanctioned ?? false)
            {
                StartSanctionCountdownTimer();
            }
            else
            {
                StopSanctionCountdownTimer();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading user violation stats: {ex.Message}");
        }
    }

    private void StartSanctionCountdownTimer()
    {
        if (sanctionTimer != null)
            return;

        sanctionTimer = new System.Timers.Timer(1000); // Обновлять каждую секунду
        sanctionTimer.Elapsed += async (sender, e) =>
        {
            if (userViolationStats?.SanctionExpiredAt.HasValue ?? false)
            {
                var remaining = userViolationStats.SanctionExpiredAt.Value - DateTime.UtcNow;

                if (remaining.TotalSeconds <= 0)
                {
                    // Санкция истекла, перезагрузить stats
                    StopSanctionCountdownTimer();
                    var contestId = ContestId ?? "contest-1";
                    await LoadUserViolationStatsAsync(contestId);
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    // Обновить таймер
                    sanctionCountdown = FormatTimeSpan(remaining);
                    await InvokeAsync(StateHasChanged);
                }
            }
        };

        sanctionTimer.AutoReset = true;
        sanctionTimer.Start();
        UpdateSanctionCountdownDisplay();
    }

    private void StopSanctionCountdownTimer()
    {
        if (sanctionTimer != null)
        {
            sanctionTimer.Stop();
            sanctionTimer.Dispose();
            sanctionTimer = null;
            sanctionCountdown = string.Empty;
        }
    }

    private void UpdateSanctionCountdownDisplay()
    {
        if (userViolationStats?.SanctionExpiredAt.HasValue ?? false)
        {
            var remaining = userViolationStats.SanctionExpiredAt.Value - DateTime.UtcNow;
            if (remaining.TotalSeconds > 0)
            {
                sanctionCountdown = FormatTimeSpan(remaining);
            }
        }
    }

    private string FormatTimeSpan(TimeSpan ts)
    {
        if (ts.TotalSeconds <= 0)
            return "00:00:00";

        var days = (int)ts.TotalDays;
        var hours = ts.Hours;
        var minutes = ts.Minutes;
        var seconds = ts.Seconds;

        if (days > 0)
            return $"{days}д {hours:D2}:{minutes:D2}:{seconds:D2}";
        else
            return $"{hours:D2}:{minutes:D2}:{seconds:D2}";
    }

    private async Task SubmitAppealAsync()
    {
        if (string.IsNullOrWhiteSpace(appealReason) || currentUser == null)
        {
            appealMessage = "Укажите причину жалобы";
            appealSuccess = false;
            return;
        }

        try
        {
            submittingAppeal = true;
            var contestId = ContestId ?? "contest-1";

            // Найти активное нарушение с санкцией
            var activeSanction = await SorrowService.GetActiveSanctionAsync(contestId, currentUser.DisplayName);
            if (activeSanction == null)
            {
                appealMessage = "Активная санкция не найдена";
                appealSuccess = false;
                return;
            }

            await AppealService.SubmitAppealAsync(activeSanction.Id, contestId, currentUser.DisplayName, appealReason);
            appealMessage = "✅ Жалоба подана! Администрация рассмотрит её в ближайшее время.";
            appealSuccess = true;
            showAppealForm = false;
            appealReason = string.Empty;
        }
        catch (InvalidOperationException ex)
        {
            appealMessage = $"⚠️ {ex.Message}";
            appealSuccess = false;
        }
        catch (Exception ex)
        {
            appealMessage = $"❌ Ошибка: {ex.Message}";
            appealSuccess = false;
        }
        finally
        {
            submittingAppeal = false;
        }
    }

    private string GetViolationTypeDisplay(ViolationType type) => type switch
    {
        ViolationType.Rudeness => "🤬 Грубость/мат/оскорбления",
        ViolationType.Trolling => "🎣 Троллинг/провокации",
        ViolationType.Spam => "📢 Спам/флуд",
        ViolationType.Other => "⚠️ Другое нарушение",
        _ => "Неизвестное нарушение"
    };
}

