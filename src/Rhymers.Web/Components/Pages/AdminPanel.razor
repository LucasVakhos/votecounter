@page "/admin-panel"
@using Rhymers.Web.Services
@using Rhymers.Core.Models
@inject AuthorizationWebService AuthService
@inject ContestService ContestService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

@if (currentUser == null)
{
    <div class="container mt-4">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">🔒 Требуется вход</h4>
            <p>Пожалуйста, авторизуйтесь.</p>
            <a href="/auth/login" class="btn btn-primary">Перейти на страницу входа</a>
        </div>
    </div>
}
else if (currentUser.Role != UserRole.Admin)
{
    <div class="container mt-4">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">⛔ Доступ запрещён</h4>
            <p>Эта страница доступна только для администраторов.</p>
            <p>Ваша текущая роль: <strong>@GetRoleDisplay(currentUser.Role)</strong></p>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-4">
        <h1>👨‍💼 Админ-панель</h1>
        
        <ul class="nav nav-tabs mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
                    👥 Пользователи (@(allUsers?.Count ?? 0))
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="moderators-tab" data-bs-toggle="tab" data-bs-target="#moderators" type="button" role="tab">
                    🔍 Модераторы (@(moderators?.Count ?? 0))
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="stats-tab" data-bs-toggle="tab" data-bs-target="#stats" type="button" role="tab">
                    📊 Статистика
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <!-- USERS TAB -->
            <div class="tab-pane fade show active" id="users" role="tabpanel">
                <div class="row">
                    <div class="col-md-12">
                        <h3>Все пользователи системы</h3>
                        
                        @if (isLoading)
                        {
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Загрузка...</span>
                            </div>
                        }
                        else if (allUsers == null || allUsers.Count == 0)
                        {
                            <div class="alert alert-info">Нет пользователей</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Имя пользователя</th>
                                            <th>Отображаемое имя</th>
                                            <th>Email</th>
                                            <th>Роль</th>
                                            <th>Статус</th>
                                            <th>Зарегистрирован</th>
                                            <th>Действия</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in allUsers)
                                        {
                                            <tr>
                                                <td><strong>@user.Username</strong></td>
                                                <td>@user.DisplayName</td>
                                                <td>@user.Email</td>
                                                <td>
                                                    <span class="badge @GetRoleBadgeClass(user.Role)">
                                                        @GetRoleDisplay(user.Role)
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (user.IsActive)
                                                    {
                                                        <span class="badge bg-success">🟢 Активен</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger">🔴 Отключен</span>
                                                    }
                                                </td>
                                                <td>@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                                <td>
                                                    @if (user.Username != currentUser.Username)
                                                    {
                                                        @if (user.IsActive)
                                                        {
                                                            <button class="btn btn-sm btn-warning" @onclick="() => ToggleUserStatusAsync(user, false)">
                                                                🔒 Отключить
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn btn-sm btn-success" @onclick="() => ToggleUserStatusAsync(user, true)">
                                                                🔓 Включить
                                                            </button>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <em class="text-muted">Это вы</em>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- MODERATORS TAB -->
            <div class="tab-pane fade" id="moderators" role="tabpanel">
                <div class="row">
                    <div class="col-md-8">
                        <h3>Управление модераторами</h3>
                        
                        @if (moderators == null || moderators.Count == 0)
                        {
                            <div class="alert alert-info">Нет модераторов</div>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var mod in moderators)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h5 class="mb-1">🔍 @mod.DisplayName (@mod.Username)</h5>
                                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveModeratorAsync(mod)">
                                                ❌ Снять с модерации
                                            </button>
                                        </div>
                                        <p class="mb-1">
                                            <strong>Email:</strong> @mod.Email<br />
                                            <strong>Конкурсы:</strong> 
                                            @if (mod.ModeratedContests?.Count > 0)
                                            {
                                                <span>@string.Join(", ", mod.ModeratedContests)</span>
                                            }
                                            else
                                            {
                                                <em class="text-muted">Нет</em>
                                            }
                                        </p>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="col-md-4">
                        <h3>Назначить модератора</h3>
                        <div class="card">
                            <div class="card-body">
                                <div class="mb-3">
                                    <label for="authorSelect" class="form-label">Выберите автора:</label>
                                    <select @bind="selectedAuthorUsername" class="form-select">
                                        <option value="">-- Выберите --</option>
                                        @if (authors != null)
                                        {
                                            @foreach (var author in authors)
                                            {
                                                <option value="@author.Username">@author.DisplayName (@author.Username)</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label for="contestSelect" class="form-label">Конкурсы:</label>
                                    <div class="form-check">
                                        @if (contests != null)
                                        {
                                            @foreach (var contest in contests)
                                            {
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" 
                                                           @onchange="e => OnContestToggleChanged(contest.Id, e)"
                                                           id="contest_@contest.Id" />
                                                    <label class="form-check-label" for="contest_@contest.Id">
                                                        @contest.Name (№@contest.Number)
                                                    </label>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>

                                <button class="btn btn-primary w-100" @onclick="AssignModeratorAsync" disabled="@string.IsNullOrEmpty(selectedAuthorUsername)">
                                    ➕ Назначить модератора
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STATS TAB -->
            <div class="tab-pane fade" id="stats" role="tabpanel">
                <div class="row">
                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">👥 Всего пользователей</h5>
                                <h2 class="card-text text-primary">@(allUsers?.Count ?? 0)</h2>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">✍️ Авторов</h5>
                                <h2 class="card-text text-success">@(authors?.Count ?? 0)</h2>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">🔍 Модераторов</h5>
                                <h2 class="card-text text-info">@(moderators?.Count ?? 0)</h2>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h5 class="card-title">👤 Читателей</h5>
                                <h2 class="card-text text-warning">@(readers?.Count ?? 0)</h2>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="card-title mb-0">📈 Детальная статистика</h5>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <strong>Активных пользователей:</strong> 
                                        @(allUsers?.Count(u => u.IsActive) ?? 0)
                                    </li>
                                    <li class="mb-2">
                                        <strong>Отключенных пользователей:</strong> 
                                        @(allUsers?.Count(u => !u.IsActive) ?? 0)
                                    </li>
                                    <li class="mb-2">
                                        <strong>Конкурсов в системе:</strong> 
                                        @(contests?.Count ?? 0)
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12">
                        <div class="card border-danger-subtle">
                            <div class="card-header">
                                <h5 class="card-title mb-0">⚠️ Рассылка предупреждения о санкциях</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3 mb-3">
                                    <div class="col-lg-6">
                                        <label class="form-label">Конкурс для автоанализа</label>
                                        <select class="form-select mb-2" @bind="sanctionsContestId">
                                            <option value="">-- выберите конкурс --</option>
                                            @if (contests != null)
                                            {
                                                @foreach (var contest in contests)
                                                {
                                                    <option value="@contest.Id">№@contest.Number - @contest.Name</option>
                                                }
                                            }
                                        </select>
                                        <div class="row g-2 mb-2">
                                            <div class="col-md-6">
                                                <label class="form-label">Мин. риск для авторассылки</label>
                                                <input type="number" min="0" max="10" step="0.1" class="form-control" @bind="sanctionsAutoRiskThreshold" />
                                                <div class="btn-group btn-group-sm mt-2" role="group" aria-label="Risk threshold presets">
                                                    <button type="button" class="@GetRiskPresetButtonClass(1.0m)" @onclick="() => SetSanctionsRiskThreshold(1.0m)">1.0</button>
                                                    <button type="button" class="@GetRiskPresetButtonClass(1.5m)" @onclick="() => SetSanctionsRiskThreshold(1.5m)">1.5</button>
                                                    <button type="button" class="@GetRiskPresetButtonClass(2.0m)" @onclick="() => SetSanctionsRiskThreshold(2.0m)">2.0</button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 d-flex align-items-end">
                                                <div class="form-check mb-1">
                                                    <input class="form-check-input" type="checkbox" id="autoSelectByRisk" @bind="autoSelectOnlyByRiskThreshold" />
                                                    <label class="form-check-label" for="autoSelectByRisk">Автодобавлять только выше порога</label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <button class="btn btn-outline-danger btn-sm" @onclick="AnalyzeSuspectsAsync" disabled="@string.IsNullOrWhiteSpace(sanctionsContestId)">Найти пойманных анализом</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="SelectAllDetectedSuspects" disabled="@(suspects.Count == 0)">Выбрать всех пойманных</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="DeselectAllDetectedSuspects" disabled="@(suspects.Count == 0)">Снять всех пойманных</button>
                                        </div>

                                        @if (suspects.Count > 0)
                                        {
                                            <div class="mt-2">
                                                <strong>Пойманные автоматически:</strong>
                                                @foreach (var suspect in suspects)
                                                {
                                                    <div class="form-check mt-1">
                                                        <input class="form-check-input" type="checkbox" id="suspect_@suspect.UserId" checked="@IsSanctionsRecipientSelected(suspect.UserId)" @onchange="e => OnSanctionsRecipientToggleChanged(suspect.UserId, e)" />
                                                        <label class="form-check-label" for="suspect_@suspect.UserId">
                                                            @suspect.DisplayName (@suspect.Username) - риск: @suspect.RiskScore.ToString("0.00")<br />
                                                            <small class="text-muted">@suspect.Reason</small>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="col-lg-6">
                                        <strong>Или выберите получателей вручную:</strong>
                                        <div class="border rounded p-2 mt-2" style="max-height: 220px; overflow-y: auto;">
                                            @if (allUsers != null)
                                            {
                                                @foreach (var user in allUsers.Where(u => u.IsActive && u.Role >= UserRole.Reader).OrderBy(u => u.DisplayName))
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input" type="checkbox" id="recipient_@user.Id" checked="@IsSanctionsRecipientSelected(user.Id)" @onchange="e => OnSanctionsRecipientToggleChanged(user.Id, e)" />
                                                        <label class="form-check-label" for="recipient_@user.Id">@user.DisplayName (@user.Username)</label>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>

                                <label class="form-label">Текст предупреждения в личные кабинеты</label>
                                <textarea class="form-control mb-2" rows="4" @bind="sanctionsWarningMessage"></textarea>
                                <div class="form-text mb-2">Подстановки: {username}, {reason}, {risk}</div>
                                <div class="d-flex gap-2 mb-3">
                                    <button class="btn btn-outline-secondary" @onclick="PreviewSanctionsMessageAsync" disabled="@(selectedSanctionsRecipientIds.Count == 0)">Предпросмотр</button>
                                    <button class="btn btn-outline-secondary" @onclick="ClearSanctionsRecipients" disabled="@(selectedSanctionsRecipientIds.Count == 0)">Сбросить выбор получателей</button>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(sanctionsPreviewText))
                                {
                                    <div class="alert alert-secondary mb-3">
                                        <strong>Предпросмотр:</strong><br />
                                        @sanctionsPreviewText
                                    </div>
                                }

                                <div class="form-text mb-3">Предупреждение отправится только выбранным получателям. При повторном нарушении в тексте указаны санкции.</div>
                                <button class="btn btn-danger" @onclick="SendSanctionsBroadcastAsync" disabled="@(selectedSanctionsRecipientIds.Count == 0)">Отправить выбранным (@selectedSanctionsRecipientIds.Count)</button>

                                @if (!string.IsNullOrWhiteSpace(sanctionsBroadcastResult))
                                {
                                    <div class="alert @(sanctionsBroadcastSuccess ? "alert-success" : "alert-warning") mt-3 mb-0">
                                        @sanctionsBroadcastResult
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private User? currentUser;
    private List<User>? allUsers;
    private List<User>? moderators;
    private List<User>? authors;
    private List<User>? readers;
    private List<Contest>? contests;
    private bool isLoading = false;

    private string selectedAuthorUsername = "";
    private List<string> selectedContestIds = new();
    private string sanctionsContestId = string.Empty;
    private List<UnfairVotingSuspect> suspects = new();
    private List<string> selectedSanctionsRecipientIds = new();
    private decimal sanctionsAutoRiskThreshold = 1.5m;
    private bool autoSelectOnlyByRiskThreshold = true;
    private string sanctionsWarningMessage = "Пользователь {username}, по результатам анализа зафиксированы признаки недобросовестной конкуренции: {reason}. Текущий риск: {risk}. Если нарушение повторится, будут применены санкции: аннулирование голосов, дисквалификация работы и ограничение участия.";
    private string sanctionsBroadcastResult = string.Empty;
    private string sanctionsPreviewText = string.Empty;
    private bool sanctionsBroadcastSuccess;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser?.Role == UserRole.Admin)
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            allUsers = await AuthService.GetAllUsersAsync(currentUser!);
            moderators = await AuthService.GetAllModeratorsAsync(currentUser!);
            
            authors = allUsers?.Where(u => u.Role == UserRole.Author).ToList();
            readers = allUsers?.Where(u => u.Role == UserRole.Reader).ToList();
            
            var contestList = (await ContestService.GetContestsAsync()).ToList();
            contests = contestList;
            sanctionsContestId = contestList.FirstOrDefault()?.Id ?? string.Empty;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleUserStatusAsync(User user, bool newStatus)
    {
        if (user.IsActive == newStatus)
            return;

        var reason = newStatus ? "Включен администратором" : "Отключен администратором";
        if (!newStatus)
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
                $"Вы уверены, что хотите отключить пользователя {user.DisplayName}?");
            if (!confirmed)
                return;

            await AuthService.DisableUserAsync(currentUser!, user.Username, reason);
        }
        
        await LoadDataAsync();
    }

    private async Task RemoveModeratorAsync(User moderator)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm",
            $"Вы уверены, что хотите снять {moderator.DisplayName} с модерации?");
        if (confirmed)
        {
            await AuthService.RemoveModeratorAsync(currentUser!, moderator.Username);
            await LoadDataAsync();
        }
    }

    private async Task AssignModeratorAsync()
    {
        if (string.IsNullOrEmpty(selectedAuthorUsername) || selectedContestIds.Count == 0)
            return;

        await AuthService.AssignModeratorAsync(currentUser!, selectedAuthorUsername, selectedContestIds);
        selectedAuthorUsername = "";
        selectedContestIds.Clear();
        await LoadDataAsync();
    }

    private async Task SendSanctionsBroadcastAsync()
    {
        if (currentUser == null)
            return;

        var sent = await ContestService.SendSanctionsWarningToUsersPersonalizedAsync(currentUser.Username, sanctionsWarningMessage, selectedSanctionsRecipientIds, suspects);
        sanctionsBroadcastSuccess = sent > 0;
        sanctionsBroadcastResult = sent > 0
            ? $"Предупреждение отправлено. Получателей: {sent}."
            : "Нет доступных получателей для рассылки.";
    }

    private async Task AnalyzeSuspectsAsync()
    {
        if (string.IsNullOrWhiteSpace(sanctionsContestId))
            return;

        suspects = await ContestService.DetectPotentialUnfairVotingAsync(sanctionsContestId);
        var threshold = sanctionsAutoRiskThreshold < 0 ? 0 : sanctionsAutoRiskThreshold;
        var autoSelected = 0;
        foreach (var suspect in suspects)
        {
            if (autoSelectOnlyByRiskThreshold && suspect.RiskScore < threshold)
                continue;

            if (!selectedSanctionsRecipientIds.Any(x => string.Equals(x, suspect.UserId, StringComparison.OrdinalIgnoreCase)))
            {
                selectedSanctionsRecipientIds.Add(suspect.UserId);
                autoSelected++;
            }
        }

        sanctionsBroadcastResult = suspects.Count > 0
            ? $"Автоанализ нашёл подозрительных пользователей: {suspects.Count}. Автодобавлено в получатели: {autoSelected} (порог риска: {threshold:0.0})."
            : "По текущему конкурсу автоанализ не выявил подозрительных пользователей.";
        sanctionsBroadcastSuccess = suspects.Count > 0;
    }

    private async Task PreviewSanctionsMessageAsync()
    {
        if (selectedSanctionsRecipientIds.Count == 0)
        {
            sanctionsPreviewText = string.Empty;
            return;
        }

        var previewUserId = selectedSanctionsRecipientIds[0];
        var previewUser = allUsers?.FirstOrDefault(u => string.Equals(u.Id, previewUserId, StringComparison.OrdinalIgnoreCase));
        if (previewUser == null)
        {
            sanctionsPreviewText = string.Empty;
            return;
        }

        var suspect = suspects.FirstOrDefault(s => string.Equals(s.UserId, previewUser.Id, StringComparison.OrdinalIgnoreCase));
        var reason = suspect?.Reason ?? "подозрительная активность по результатам проверки";
        var risk = (suspect?.RiskScore ?? 0m).ToString("0.00");

        sanctionsPreviewText = (sanctionsWarningMessage ?? string.Empty)
            .Replace("{username}", previewUser.Username, StringComparison.OrdinalIgnoreCase)
            .Replace("{reason}", reason, StringComparison.OrdinalIgnoreCase)
            .Replace("{risk}", risk, StringComparison.OrdinalIgnoreCase);

        await Task.CompletedTask;
    }

    private void OnSanctionsRecipientToggleChanged(string userId, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool flag && flag;
        if (isChecked)
        {
            if (!selectedSanctionsRecipientIds.Any(x => string.Equals(x, userId, StringComparison.OrdinalIgnoreCase)))
                selectedSanctionsRecipientIds.Add(userId);
            return;
        }

        selectedSanctionsRecipientIds.RemoveAll(x => string.Equals(x, userId, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsSanctionsRecipientSelected(string userId)
    {
        return selectedSanctionsRecipientIds.Any(x => string.Equals(x, userId, StringComparison.OrdinalIgnoreCase));
    }

    private void ClearSanctionsRecipients()
    {
        selectedSanctionsRecipientIds.Clear();
        sanctionsPreviewText = string.Empty;
        sanctionsBroadcastResult = "Список получателей очищен.";
        sanctionsBroadcastSuccess = false;
    }

    private void SelectAllDetectedSuspects()
    {
        var added = 0;
        foreach (var suspect in suspects)
        {
            if (selectedSanctionsRecipientIds.Any(x => string.Equals(x, suspect.UserId, StringComparison.OrdinalIgnoreCase)))
                continue;

            selectedSanctionsRecipientIds.Add(suspect.UserId);
            added++;
        }

        sanctionsBroadcastResult = added > 0
            ? $"Добавлено пойманных получателей: {added}."
            : "Все пойманные уже выбраны.";
        sanctionsBroadcastSuccess = added > 0;
    }

    private void DeselectAllDetectedSuspects()
    {
        if (suspects.Count == 0)
            return;

        var suspectIds = suspects.Select(x => x.UserId).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var before = selectedSanctionsRecipientIds.Count;
        selectedSanctionsRecipientIds.RemoveAll(x => suspectIds.Contains(x));
        var removed = before - selectedSanctionsRecipientIds.Count;

        sanctionsBroadcastResult = removed > 0
            ? $"Снято пойманных получателей: {removed}."
            : "Пойманные пользователи не были выбраны.";
        sanctionsBroadcastSuccess = removed > 0;
    }

    private void SetSanctionsRiskThreshold(decimal value)
    {
        sanctionsAutoRiskThreshold = value;
    }

    private string GetRiskPresetButtonClass(decimal preset)
    {
        return Math.Abs(sanctionsAutoRiskThreshold - preset) < 0.01m
            ? "btn btn-secondary"
            : "btn btn-outline-secondary";
    }

    private void ToggleContest(string contestId, bool isChecked)
    {
        if (isChecked)
        {
            if (!selectedContestIds.Contains(contestId))
                selectedContestIds.Add(contestId);
        }
        else
        {
            selectedContestIds.Remove(contestId);
        }
    }

    private void OnContestToggleChanged(string contestId, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool flag && flag;
        ToggleContest(contestId, isChecked);
    }

    private string GetRoleDisplay(UserRole role) => role switch
    {
        UserRole.Reader => "👤 Читатель/Оценщик",
        UserRole.Author => "✍️ Автор",
        UserRole.Moderator => "🔍 Модератор",
        UserRole.Admin => "👨‍💼 Администратор",
        _ => "?"
    };

    private string GetRoleBadgeClass(UserRole role) => role switch
    {
        UserRole.Reader => "bg-info",
        UserRole.Author => "bg-success",
        UserRole.Moderator => "bg-warning text-dark",
        UserRole.Admin => "bg-danger",
        _ => "bg-secondary"
    };
}
