@page "/profile"
@using Rhymers.Core.Models
@using Rhymers.Web.Services
@inject AuthorizationWebService AuthService
@inject ContestService ContestService
@inject DiscussionService DiscussionService
@inject SorrowChatWebService SorrowService
@inject IJSRuntime JS

<PageTitle>Профиль</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8">
            @if (currentUser == null)
            {
                <div class="alert alert-warning">
                    <strong>⚠️ Вход требуется</strong><br>
                    Пожалуйста, <a href="auth/login">войдите в систему</a> для просмотра профиля.
                </div>
            }
            else
            {
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">👤 Профиль пользователя</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Имя:</dt>
                            <dd class="col-sm-9"><strong>@currentUser.DisplayName</strong></dd>

                            <dt class="col-sm-3">Роль:</dt>
                            <dd class="col-sm-9">
                                <span class="badge @GetRoleBadgeClass(currentUser.Role)">
                                    @GetRoleDisplay(currentUser.Role)
                                </span>
                            </dd>

                            <dt class="col-sm-3">Призов:</dt>
                            <dd class="col-sm-9">
                                <strong>@userPrizes.Count</strong> достижений
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">🛡️ Нарушения и санкции</h5>
                        @if (userViolations.Count > 0 && userViolations.All(v => v.IsCleared))
                        {
                            <span class="badge bg-success">✅ Реабилитирован</span>
                        }
                    </div>
                    <div class="card-body">
                        @if (userViolationStats?.IsSanctioned ?? false)
                        {
                            <div class="alert alert-warning py-2">
                                <strong>Активная санкция:</strong> @GetSanctionDisplay(userViolationStats!.CurrentSanction)
                                @if (userViolationStats.SanctionExpiredAt.HasValue)
                                {
                                    <span> до @userViolationStats.SanctionExpiredAt.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                }
                                @if (!string.IsNullOrEmpty(userViolationStats.SanctionReason))
                                {
                                    <br />
                                    <small>Причина: @userViolationStats.SanctionReason</small>
                                }
                            </div>
                        }

                        @if (userViolations.Count == 0)
                        {
                            <div class="text-muted">Нарушений не зафиксировано.</div>
                        }
                        else
                        {
                            <div class="mb-3 small text-muted">
                                Видимость: для вас и модераторов/администраторов.
                            </div>
                            <div class="timeline-list">
                                @foreach (var v in userViolations.OrderByDescending(x => x.CreatedAt))
                                {
                                    <div class="border rounded p-2 mb-2">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <div>
                                                <span class="badge @GetViolationBadgeClass(v.Type)">@GetViolationDisplay(v.Type)</span>
                                                @if (v.IsCleared)
                                                {
                                                    <span class="badge bg-success ms-1">Снято</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark ms-1">Активно</span>
                                                }
                                                @if (v.Sanction != SanctionType.None)
                                                {
                                                    <span class="badge bg-danger ms-1">@GetSanctionDisplay(v.Sanction)</span>
                                                }
                                            </div>
                                            <small class="text-muted">@v.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                        </div>
                                        @if (!string.IsNullOrEmpty(v.Details))
                                        {
                                            <div class="small">@v.Details</div>
                                        }
                                        @if (v.IsCleared && v.ClearedAt.HasValue)
                                        {
                                            <small class="text-success">Снято: @v.ClearedAt.Value.ToString("dd.MM.yyyy HH:mm")</small>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">🏆 Полка призов</h5>
                        @if (userPrizes.Count > 0)
                        {
                            <button class="btn btn-sm btn-light" @onclick="ExportAsPrizeImageAsync" disabled="@isExporting">
                                @if (isExporting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Сохраняем...</span>
                                }
                                else
                                {
                                    <span>📸 Экспортировать</span>
                                }
                            </button>
                        }
                    </div>
                    <div class="card-body">
                        @if (userPrizes.Count == 0)
                        {
                            <div class="text-center text-muted py-4">
                                <p>📭 Пока нет достижений</p>
                                <p class="small">Начните участвовать в конкурсах, чтобы попасть в зал славы!</p>
                            </div>
                        }
                        else
                        {
                            <div id="prizeShelf" class="prize-shelf">
                                <div class="row">
                                    @foreach (var prize in userPrizes.OrderBy(p => p.Place))
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="prize-card @GetPrizeCardClass(prize.Place)">
                                                <div class="prize-header">
                                                    <span class="prize-place-badge">@GetPlaceBadge(prize.Place)</span>
                                                    <span class="prize-date small">@prize.ContestDate.ToShortDateString()</span>
                                                </div>
                                                <div class="prize-body">
                                                    <h6 class="prize-title">@prize.Topic</h6>
                                                    <p class="prize-scores">
                                                        <small>
                                                            Сумма: <strong>@prize.TotalScore.ToString("F2")</strong> |
                                                            Средняя: <strong>@prize.AverageScore.ToString("F2")</strong>
                                                        </small>
                                                    </p>
                                                    <p class="prize-votes small text-muted">
                                                        Голосов: @prize.VotesCount
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="mt-4 pt-3 border-top text-center text-muted small">
                                <p>📊 Статистика</p>
                                <div class="row">
                                    <div class="col">
                                        <strong>@userPrizes.Count(p => p.Place == 1)</strong><br>
                                        <span class="small">🥇 1-е места</span>
                                    </div>
                                    <div class="col">
                                        <strong>@userPrizes.Count(p => p.Place == 2)</strong><br>
                                        <span class="small">🥈 2-е места</span>
                                    </div>
                                    <div class="col">
                                        <strong>@userPrizes.Count(p => p.Place == 3)</strong><br>
                                        <span class="small">🥉 3-е места</span>
                                    </div>
                                    <div class="col">
                                        <strong>@userPrizes.Count(p => p.Place == 0)</strong><br>
                                        <span class="small">⭐ Номинации</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (userReviews.Count > 0)
                {
                    <div class="card">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">⭐ Рецензии на мои работы</h5>
                        </div>
                        <div class="card-body">
                            @foreach (var review in userReviews.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="card mb-3 border-left-primary">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h6 class="card-subtitle mb-1">
                                                    <strong>Работа №@review.WorkNumber: @review.WorkTitle</strong>
                                                </h6>
                                                <small class="text-muted">Рецензия от <strong>@review.ReviewerName</strong> (@GetRoleDisplay(review.ReviewerRole))</small>
                                            </div>
                                            @if (review.Rating.HasValue)
                                            {
                                                <div class="text-warning">
                                                    @for (int i = 0; i < review.Rating; i++)
                                                    {
                                                        <span>⭐</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <h6 class="mt-2">@review.Title</h6>
                                        <p class="card-text">@review.Content</p>
                                        @if (!string.IsNullOrEmpty(review.Strengths))
                                        {
                                            <p class="mb-2">
                                                <small class="text-success"><strong>✓ Достоинства:</strong> @review.Strengths</small>
                                            </p>
                                        }
                                        @if (!string.IsNullOrEmpty(review.AreasForImprovement))
                                        {
                                            <p class="mb-2">
                                                <small class="text-warning"><strong>→ На улучшение:</strong> @review.AreasForImprovement</small>
                                            </p>
                                        }
                                        <small class="text-muted d-block mt-2">@review.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    .prize-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 12px;
        background: #fff;
        transition: all 0.3s ease;
    }

    .prize-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .prize-card.place-1 {
        border-left: 4px solid gold;
        background: #fffbf0;
    }

    .prize-card.place-2 {
        border-left: 4px solid silver;
        background: #f8f9fa;
    }

    .prize-card.place-3 {
        border-left: 4px solid #cd7f32;
        background: #faf7f2;
    }

    .prize-card.nomination {
        border-left: 4px solid #17a2b8;
        background: #f0f8ff;
    }

    .prize-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .prize-place-badge {
        font-size: 1.2em;
        font-weight: bold;
    }

    .prize-body h6 {
        margin: 8px 0;
        color: #333;
    }

    .prize-scores {
        margin: 6px 0;
        color: #666;
    }

    .prize-votes {
        margin: 6px 0 0 0;
    }

    .prize-shelf {
        margin: 15px 0;
    }
</style>

@code {
    private User? currentUser;
    private List<HallOfFameEntry> userPrizes = new();
    private List<WorkReview> userReviews = new();
    private List<UserViolation> userViolations = new();
    private UserViolationStats? userViolationStats;
    private bool isExporting = false;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
        if (currentUser?.DisplayName != null)
        {
            userPrizes = await ContestService.GetUserHallOfFameEntriesAsync(currentUser.DisplayName);
            userReviews = await DiscussionService.GetReviewsReceivedByAuthorAsync(currentUser.DisplayName);

            var contestId = "contest-1";
            var contestViolations = await SorrowService.GetContestViolationsAsync(contestId, false);
            userViolations = contestViolations
                .Where(v => v.UserName.Equals(currentUser.DisplayName, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(v => v.CreatedAt)
                .ToList();

            userViolationStats = await SorrowService.GetUserViolationStatsAsync(contestId, currentUser.DisplayName);
        }
    }

    private string GetRoleBadgeClass(UserRole role) => role switch
    {
        UserRole.Admin => "bg-danger",
        UserRole.Moderator => "bg-warning",
        UserRole.Author => "bg-info",
        _ => "bg-secondary"
    };

    private string GetRoleDisplay(UserRole role) => role switch
    {
        UserRole.Admin => "👨‍💼 Администратор",
        UserRole.Developer => "👨‍💻 Разработчик",
        UserRole.Moderator => "👮 Модератор",
        UserRole.Author => "✍️ Автор",
        _ => "👤 Читатель"
    };

    private string GetViolationDisplay(ViolationType type) => type switch
    {
        ViolationType.Rudeness => "🤬 Грубость",
        ViolationType.Trolling => "🎣 Троллинг",
        ViolationType.Spam => "📢 Спам",
        ViolationType.Other => "⚠️ Прочее",
        _ => "Нарушение"
    };

    private string GetViolationBadgeClass(ViolationType type) => type switch
    {
        ViolationType.Rudeness => "bg-danger",
        ViolationType.Trolling => "bg-danger",
        ViolationType.Spam => "bg-warning text-dark",
        ViolationType.Other => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetSanctionDisplay(SanctionType type) => type switch
    {
        SanctionType.OneDay => "⏰ 1 день",
        SanctionType.OneWeek => "📅 7 дней",
        SanctionType.OneMonth => "🗓️ 30 дней",
        SanctionType.Permanent => "♾️ Постоянно",
        _ => "Без санкции"
    };

    private string GetPlaceBadge(int place) => place switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        0 => "⭐",
        _ => "🎖️"
    };

    private string GetPrizeCardClass(int place) => place switch
    {
        1 => "prize-card place-1",
        2 => "prize-card place-2",
        3 => "prize-card place-3",
        0 => "prize-card nomination",
        _ => "prize-card nomination"
    };

    private async Task ExportAsPrizeImageAsync()
    {
        isExporting = true;
        try
        {
            // Используем JS для экспорта через html2canvas
            await JS.InvokeVoidAsync("exportPrizeShelfAsImage", currentUser?.DisplayName ?? "Мои призы");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Export error: {ex.Message}");
        }
        finally
        {
            isExporting = false;
        }
    }
}
